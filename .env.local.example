# LIFF
NEXT_PUBLIC_LIFF_ID=
LINE_LOGIN_CHANNEL_ID=

# LIFF dev mock (set to "true" to skip real LIFF init in local dev)
# NEXT_PUBLIC_LIFF_MOCK=true
# NEXT_PUBLIC_LIFF_MOCK_USER_ID=Umock_dev_user
# NEXT_PUBLIC_LIFF_MOCK_DISPLAY_NAME=Dev User
# NEXT_PUBLIC_LIFF_MOCK_PICTURE_URL=
# Server-side mirror (must match NEXT_PUBLIC_LIFF_MOCK_USER_ID)
# LIFF_MOCK_USER_ID=Umock_dev_user
# LIFF_MOCK_DISPLAY_NAME=Dev User

# Supabase (https://supabase.com → project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LINE Messaging API (separate channel for push notifications)
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
LINE_MESSAGING_CHANNEL_SECRET=

# Misc
TZ_DEFAULT=Asia/Bangkok
# Long random string. Cron jobs must send Authorization: Bearer <secret>
PUSH_CRON_SECRET=
